{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard Manager Tauri",
  "version": "1.0.0",
  "identifier": "app.clipboard-manager-tauri",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Clipboard Manager",
        "width": 1000,
        "height": 700,
        "minWidth": 520,
        "minHeight": 360,
        "decorations": false,
        "backgroundColor": "#0b0b0b",
        "resizable": true,
        "visible": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-gpu"
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: http://asset.localhost blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
